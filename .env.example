# ─────────────────────────────────────────────────────────────
#  Innie — Internee.pk Chatbot  |  .env config
#  RENAME THIS FILE TO:  .env
# ─────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════
#  OPTION A — GROQ (FREE, Fast, Recommended)
#  Get key: https://console.groq.com
#  Sign up → API Keys → Create Key → copy gsk_...
# ══════════════════════════════════════════════
GROQ_API_KEY=gsk_your_groq_api_key_here

# ══════════════════════════════════════════════
#  OPTION B — OpenAI (if you prefer)
#  Get key: https://platform.openai.com/api-keys
#  Comment out GROQ_API_KEY above if using this
# ══════════════════════════════════════════════
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Session security key — any random string is fine
SECRET_KEY=internee-chatbot-super-secret-2024
